# Copy to `.env.local`. Prefer RABOTA_HH_USER_AGENT so IDE/shell HH_USER_AGENT cannot override.
#
#   RABOTA_HH_USER_AGENT=YourUniqueApp/1.0 (you@mail.ru)
#
# Optional fallback (ignored by Next if HH_USER_AGENT is already set in the parent process):
#   HH_USER_AGENT=YourUniqueApp/1.0 (you@mail.ru)
#
# Restart: npm run dev
# https://github.com/hhru/api
